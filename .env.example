# ENTORNO
APP_ENV=pruebas
TIMEZONE=Europe/Madrid

# MODELO LLM
LLM_PROVIDER=groq
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1200

# CUENTA GMAIL DE PRUEBAS
EXPECTED_GMAIL_ADDRESS=agentesectretarioampa@gmail.com
GOOGLE_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token_gmail.json

# Modo inicial:
# lectura = solo leer y analizar
# gestion = permite crear borradores y cambiar leído/no leído
GMAIL_ACCESS_MODE=lectura
GMAIL_QUERY=is:unread in:inbox
MAX_EMAILS_PER_RUN=5

# ACCIONES PERMITIDAS
ALLOW_EMAIL_SEND=false
ALLOW_CREATE_DRAFTS=false
ALLOW_MODIFY_LABELS=false

# MEMORIA LOCAL
DATABASE_PATH=data/secretario_ampa.db

# PROMPT
SYSTEM_PROMPT_PATH=prompts/system_prompt_secretario.md
MAX_BODY_CHARS=8000
