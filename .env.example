# ============================================================
# ENTORNO
# ============================================================
APP_ENV=pruebas
TIMEZONE=Europe/Madrid

# ============================================================
# MODELO LLM
# ============================================================
LLM_PROVIDER=groq
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.1-8b-instant
# LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=1200

# ============================================================
# COMPOSIO
# ============================================================
COMPOSIO_API_KEY=
COMPOSIO_USER_ID=secretario_ampa_pruebas
EXPECTED_GMAIL_ADDRESS=agentesectretarioampa@gmail.com

# ============================================================
# GMAIL
# ============================================================
GMAIL_QUERY=is:unread in:inbox
MAX_EMAILS_PER_RUN=20
ALLOW_CREATE_DRAFTS=true
ALLOW_MARK_AS_READ=true
ALLOW_EMAIL_SEND=false

# Acción principal prevista por Composio para quitar UNREAD.
# El código también busca alternativas disponibles en la sesión.
GMAIL_MARK_READ_ACTION=GMAIL_MODIFY_EMAIL_LABELS

# ============================================================
# CALENDAR
# ============================================================
CALENDAR_ID=primary
DEFAULT_MEETING_MINUTES=60
ALLOW_CREATE_EVENTS=false

# ============================================================
# RAG SEPARADO
# ============================================================
RAG_YEARS=1
RAG_MAX_EMAILS=200
RAG_RESULTS=3
RAG_MIN_SIMILARITY=0.20

# ============================================================
# WHATSAPP
# ============================================================
# En V0.3 se recomienda mantenerlo en simulado.
WHATSAPP_MODE=simulado
WHATSAPP_RECIPIENTS=Presidencia,Secretaría

# ============================================================
# SERVICIO
# ============================================================
ORDINARY_START_HOUR=6
ORDINARY_END_HOUR=23
SCHEDULER_CHECK_SECONDS=60

# ============================================================
# SALIDA
# ============================================================
SHOW_STEPS=true
