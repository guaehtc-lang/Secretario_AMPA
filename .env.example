# Claves
LLM_API_KEY=
COMPOSIO_API_KEY=

# LLM
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.1-8b-instant
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=700
MAX_PASOS=8
MOSTRAR_PASOS=false

# Composio
COMPOSIO_USER_ID=secretario_ampa_pruebas

# Gmail
GMAIL_QUERY=is:unread in:inbox
MAX_CORREOS_BUSQUEDA=10

# Calendar
TIMEZONE=Europe/Madrid
CALENDAR_ID=primary

# Acciones
ALLOW_CREATE_DRAFTS=true
ALLOW_CREATE_EVENTS=true

# RAG
RAG_ANIOS_HISTORIAL=1
RAG_MAX_CORREOS=200
RAG_RESULTADOS=3

# Servicio
HORA_INICIO=6
HORA_FIN=23
SEGUNDOS_COMPROBACION=60
