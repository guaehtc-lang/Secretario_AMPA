# ============================================================
# ENTORNO
# ============================================================
APP_ENV=pruebas
TIMEZONE=Europe/Madrid

# ============================================================
# MODELO LLM
# ============================================================
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.1-8b-instant
# LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=1200

# ============================================================
# COMPOSIO
# ============================================================
COMPOSIO_API_KEY=
COMPOSIO_USER_ID=secretario_ampa_pruebas

# ============================================================
# GMAIL
# ============================================================
GMAIL_QUERY=is:unread in:inbox
MAX_EMAILS_PER_RUN=20
ALLOW_CREATE_DRAFTS=true
ALLOW_MARK_AS_READ=true

# Seguridad: activar solo después de validar el flujo completo.
ALLOW_EMAIL_SEND=false
GMAIL_MARK_READ_ACTION=GMAIL_MODIFY_EMAIL_LABELS

# ============================================================
# GOOGLE CALENDAR
# ============================================================
CALENDAR_ID=primary
DEFAULT_MEETING_MINUTES=60

# Seguridad: activar solo después de validar la creación de eventos.
ALLOW_CREATE_EVENTS=false

# ============================================================
# RAG LOCAL
# ============================================================
RAG_RESULTS=3
RAG_MIN_SIMILARITY=0.20

# ============================================================
# TELEGRAM
# ============================================================
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_POLLING_TIMEOUT=5
TELEGRAM_REQUEST_TIMEOUT=15

# ============================================================
# SERVICIO LOCAL
# ============================================================
# Configuración actual de pruebas. Se ajustará al usar el Gmail real del AMPA.
ORDINARY_START_HOUR=0
ORDINARY_END_HOUR=23
GMAIL_CHECK_SECONDS=30
TELEGRAM_CHECK_SECONDS=15
SERVICE_LOOP_SECONDS=2

# ============================================================
# SALIDA
# ============================================================
SHOW_STEPS=true
